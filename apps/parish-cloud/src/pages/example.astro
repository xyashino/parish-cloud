---
import Layout from '../layouts/Layout.astro';
import ExampleCard from '../components/ExampleCard';
---

<Layout>
  <main class="mx-auto max-w-2xl space-y-8 px-4 py-12">
    <header class="text-center">
      <h1 class="text-3xl font-bold tracking-tight text-slate-900">
        Tailwind + React test
      </h1>
      <p class="mt-2 text-slate-600">
        This page uses Tailwind in Astro and a React component with Tailwind.
      </p>
    </header>

    <section class="rounded-2xl bg-slate-100/80 p-6">
      <h2 class="mb-4 text-lg font-semibold text-slate-800">
        Astro + Tailwind (static)
      </h2>
      <p class="text-slate-600">
        This section is plain Astro with Tailwind utility classes. No React
        hydration.
      </p>
      <div class="mt-4 flex flex-wrap gap-2">
        <span class="rounded-full bg-indigo-100 px-3 py-1 text-sm text-indigo-800">
          Tailwind
        </span>
        <span class="rounded-full bg-slate-200 px-3 py-1 text-sm text-slate-700">
          Astro
        </span>
      </div>
    </section>

    <section>
      <h2 class="mb-4 text-lg font-semibold text-slate-800">
        React component (hydrated)
      </h2>
      <ExampleCard client:load />
    </section>

    <footer class="border-t border-slate-200 pt-6 text-center text-sm text-slate-500">
      <a href="/" class="text-indigo-600 hover:underline">← Back to home</a>
    </footer>
  </main>
</Layout>
